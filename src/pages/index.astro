---
import Layout from '../layouts/Layout.astro';

const navItems = [
  { label: 'About', href: '/about/', number: '01', desc: '私のこと' },
  { label: 'Works', href: '/works/', number: '02', desc: 'これまでの活動' },
  { label: 'Skills', href: '/skills/', number: '03', desc: '触ってきたもの' },
  { label: 'Links', href: '/contact/', number: '04', desc: 'ここにいます' },
] as const;
---

<Layout title="Haruworld — Engineer & Designer">
  <!-- ローディングオーバーレイ -->
  <div class="loader" id="loader">
    <div class="loader__inner">
      <div class="loader__wave">
        {'Loading...'.split('').map((char, i) => (
          <span class="loader__char" style={`animation-delay: ${i * 0.08}s`}>{char}</span>
        ))}
      </div>
      <div class="loader__faces">
        <span class="loader__face">0x0</span>
        <span class="loader__face">0x0</span>
        <span class="loader__face">0x0</span>
      </div>
    </div>
  </div>

  <div class="home" id="home">
    <div class="home__inner">
      <header class="home__header">
        <p class="home__role" id="home-role">Engineer & Designer</p>
        <h1 class="home__name" id="home-name">Haruworld<span class="home__cursor">|</span></h1>
      </header>

      <hr class="deco-line" id="home-line" />

      <nav class="home__nav" id="home-nav">
        {
          navItems.map((item, i) => (
            <a href={item.href} class="home__nav-item" data-delay={i * 80}>
              <span class="home__nav-number">{item.number}</span>
              <span class="home__nav-label">{item.label}</span>
              <span class="home__nav-desc">{item.desc}</span>
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</Layout>

<script>
  function initHome(): void {
    const loader = document.getElementById('loader');
    const loaderFaces = document.querySelectorAll('.loader__face');
    const home = document.getElementById('home');
    const homeRole = document.getElementById('home-role');
    const homeName = document.getElementById('home-name');
    const homeLine = document.getElementById('home-line');
    const homeNav = document.getElementById('home-nav');

    if (!home || !homeRole || !homeName || !homeLine || !homeNav) return;

    function typeText(el: HTMLElement, text: string, speed: number): Promise<void> {
      return new Promise((resolve) => {
        let i = 0;
        const interval = setInterval(() => {
          el.textContent += text[i];
          i++;
          if (i >= text.length) {
            clearInterval(interval);
            resolve();
          }
        }, speed);
      });
    }

    function typeTextNode(node: Text, text: string, speed: number): Promise<void> {
      return new Promise((resolve) => {
        let i = 0;
        const interval = setInterval(() => {
          node.textContent += text[i];
          i++;
          if (i >= text.length) {
            clearInterval(interval);
            resolve();
          }
        }, speed);
      });
    }

    function wait(ms: number): Promise<void> {
      return new Promise((r) => setTimeout(r, ms));
    }

    async function startOpening(): Promise<void> {
      document.body.style.overflow = 'hidden';

      if (loader && loaderFaces.length > 0) {
        await wait(1800);

        function spawnParticles(el: HTMLElement, mode: 'gather' | 'burst'): void {
          const rect = el.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;

          for (let j = 0; j < 8; j++) {
            const dot = document.createElement('span');
            dot.className = mode === 'gather' ? 'loader__particle--gather' : 'loader__particle';
            const angle = (Math.PI * 2 * j) / 8 + (Math.random() - 0.5) * 0.4;
            const dist = 30 + Math.random() * 40;
            const tx = Math.cos(angle) * dist;
            const ty = Math.sin(angle) * dist;
            dot.style.left = `${cx}px`;
            dot.style.top = `${cy}px`;
            dot.style.setProperty('--tx', `${tx}px`);
            dot.style.setProperty('--ty', `${ty}px`);
            document.body.appendChild(dot);
          }
        }

        const delays = [0, 500, 800];
        for (let i = 0; i < loaderFaces.length; i++) {
          await wait(delays[i]);
          const el = loaderFaces[i] as HTMLElement;
          spawnParticles(el, 'gather');
          el.classList.add('is-visible');
        }
        await wait(1200);

        loaderFaces.forEach((face) => {
          const el = face as HTMLElement;
          spawnParticles(el, 'burst');
          el.classList.add('is-pop');
        });
        await wait(600);

        loader.classList.add('is-hidden');
        await wait(700);
        loader.style.pointerEvents = 'none';
      }

      home.classList.add('is-visible');

      await wait(400);
      homeRole.classList.add('is-visible');
      await wait(200);

      const cursor = homeName.querySelector('.home__cursor') as HTMLElement;
      homeName.childNodes.forEach((node) => {
        if (node.nodeType === Node.TEXT_NODE) node.textContent = '';
      });
      homeName.classList.add('is-visible');
      cursor.classList.add('is-typing');
      const nameTextNode = document.createTextNode('');
      homeName.insertBefore(nameTextNode, cursor);
      await typeTextNode(nameTextNode, 'Haruworld', 60);
      cursor.classList.remove('is-typing');
      cursor.classList.add('is-idle');

      await wait(300);
      homeLine.classList.add('is-visible');
      await wait(200);

      const items = homeNav.querySelectorAll('.home__nav-item');
      for (const item of items) {
        const el = item as HTMLElement;
        const delay = el.dataset.delay;
        if (delay) await wait(parseInt(delay));
        el.classList.add('is-visible');

        const label = el.querySelector('.home__nav-label') as HTMLElement;
        if (label) {
          const text = label.textContent || '';
          label.textContent = '';
          await typeText(label, text, 40);
        }
      }

      document.body.style.overflow = '';
    }

    startOpening();
  }

  initHome();
  document.addEventListener('astro:after-swap', initHome);
</script>

<style>
  /* ─── Loader ─── */
  .loader {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .loader.is-hidden {
    animation: wipe-out 0.7s cubic-bezier(0.76, 0, 0.24, 1) forwards;
  }

  @keyframes wipe-out {
    0% {
      clip-path: inset(0 0 0 0);
    }
    100% {
      clip-path: inset(0 0 100% 0);
    }
  }

  .loader__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .loader__wave {
    display: flex;
    align-items: center;
  }

  .loader__char {
    font-family: var(--font-main);
    font-size: clamp(0.9rem, 2vw, 1.2rem);
    font-weight: 400;
    color: var(--color-bg);
    display: inline-block;
    animation: wave 1.2s ease-in-out infinite;
    opacity: 0.7;
  }

  .loader__faces {
    display: flex;
    gap: 2.5rem;
  }

  .loader__face {
    position: relative;
    font-family: var(--font-main);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-bg);
    opacity: 0;
  }

  .loader__face.is-visible {
    animation: pop-in 0.2s ease-out forwards;
  }

  @keyframes pop-in {
    0% {
      opacity: 0;
      transform: scale(0);
    }
    70% {
      opacity: 1;
      transform: scale(1.1);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  .loader__face.is-pop {
    animation: pop-text 0.2s ease-out forwards;
  }

  @keyframes pop-text {
    0% {
      opacity: 1;
      transform: scale(1);
    }
    20% {
      opacity: 1;
      transform: scale(1.1);
    }
    100% {
      opacity: 0;
      transform: scale(0);
    }
  }

  @keyframes wave {
    0%, 100% { transform: translateY(0); }
    30% { transform: translateY(-0.4em); }
    60% { transform: translateY(0); }
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ─── Home ─── */
  .home {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem;
    position: relative;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .home.is-visible {
    opacity: 1;
  }

  .home__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--max-width);
  }

  .home__header {
    margin-bottom: 1rem;
  }

  .home__role {
    font-family: var(--font-main);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 0.2em;
    margin-bottom: 1rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .home__role.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .home__name {
    font-family: var(--font-main);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .home__name.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .home__cursor {
    font-weight: 400;
    opacity: 0;
  }

  .home__cursor.is-typing {
    opacity: 1;
    animation: blink 0.8s step-end infinite;
  }

  .home__cursor.is-idle {
    opacity: 1;
    animation: blink 1.2s step-end infinite;
  }

  #home-line {
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  #home-line.is-visible {
    opacity: 1;
  }

  .home__nav {
    display: flex;
    flex-direction: column;
  }

  .home__nav-item {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-line);
    transition: color 0.3s ease, opacity 0.5s ease, transform 0.5s ease;
    opacity: 0;
    transform: translateY(8px);
  }

  .home__nav-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .home__nav-item:hover {
    color: var(--color-accent);
  }

  .home__nav-number {
    font-family: var(--font-main);
    font-size: 1.5rem;
    color: var(--color-line);
    min-width: 2.5rem;
    transition: color 0.3s ease;
  }

  .home__nav-item:hover .home__nav-number {
    color: var(--color-accent);
  }

  .home__nav-label {
    font-family: var(--font-main);
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .home__nav-desc {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-left: auto;
  }

  @media (max-width: 768px) {
    .home {
      padding: 3rem 1.5rem;
    }

    .home__nav-item {
      flex-wrap: wrap;
    }

    .home__nav-desc {
      width: 100%;
      margin-left: 0;
      padding-left: 4rem;
    }
  }
</style>

<style is:global>
  .loader__particle {
    position: fixed;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-bg);
    pointer-events: none;
    z-index: 201;
    animation: particle-fly 0.4s ease-out forwards;
  }

  @keyframes particle-fly {
    0% {
      opacity: 1;
      transform: translate(0, 0) scale(1);
    }
    100% {
      opacity: 0;
      transform: translate(var(--tx), var(--ty)) scale(0);
    }
  }

  .loader__particle--gather {
    position: fixed;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-bg);
    pointer-events: none;
    z-index: 201;
    animation: particle-gather 0.35s ease-in forwards;
  }

  @keyframes particle-gather {
    0% {
      opacity: 1;
      transform: translate(0, 0) scale(1);
    }
    100% {
      opacity: 0;
      transform: translate(var(--tx), var(--ty)) scale(0);
    }
  }
</style>
