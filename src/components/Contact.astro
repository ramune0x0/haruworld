---
import { Icon } from 'astro-icon/components';

const links = [
  {
    name: 'GitHub',
    icon: 'simple-icons:github',
    color: '#181717',
    url: 'https://github.com/ramune0x0',
  },
  {
    name: 'X',
    icon: 'simple-icons:x',
    color: '#000000',
    url: 'https://x.com/_ramune0x0',
  },
  {
    name: 'Instagram',
    icon: 'simple-icons:instagram',
    color: '#E4405F',
    url: '#',
  },
  {
    name: 'Email',
    icon: 'mdi:email-outline',
    color: '#4285F4',
    url: 'mailto:h.minemura.0x@gmail.com',
  },
] as const;
---

<div class="contact" data-animate>
  <ul class="contact__list">
    {
      links.map((link) => (
        <li>
          <a
            href={link.url}
            class="contact__item"
            style={`--brand-color: ${link.color}`}
            target={link.url.startsWith('mailto') ? undefined : '_blank'}
            rel={link.url.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          >
            <Icon name={link.icon} class="contact__icon" />
            <span class="contact__name">{link.name}</span>
          </a>
        </li>
      ))
    }
  </ul>
  <p class="contact__copy">&copy; 2026 Haruworld</p>
</div>

<style>
  .contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    padding: 4rem 0;
  }

  .contact__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 3rem;
  }

  .contact__copy {
    font-family: var(--font-main);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .contact__item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
  }

  .contact__icon {
    width: 48px;
    height: 48px;
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }

  .contact__item:hover .contact__icon {
    color: var(--brand-color);
  }

  .contact__name {
    position: absolute;
    bottom: -1.75rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-main);
    font-size: 0.75rem;
    color: var(--brand-color);
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  .contact__item:hover .contact__name {
    opacity: 1;
  }
</style>
