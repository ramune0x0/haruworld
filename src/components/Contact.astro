---
import { Icon } from 'astro-icon/components';

const links = [
  {
    name: 'GitHub',
    icon: 'simple-icons:github',
    color: '#181717',
    url: 'https://github.com/ramune0x0',
  },
  {
    name: 'X',
    icon: 'simple-icons:x',
    color: '#000000',
    url: 'https://x.com/_ramune0x0',
  },
  {
    name: 'Instagram',
    icon: 'simple-icons:instagram',
    color: '#E4405F',
    url: 'https://www.instagram.com/0xhar_u/',
  },
  {
    name: 'Email',
    icon: 'mdi:email-outline',
    color: '#4285F4',
    url: '#',
    email: 'h.minemura.0x@gmail.com',
  },
] as const;
---

<div class="contact" data-animate>
  <ul class="contact__list">
    {
      links.map((link) => (
        <li>
          {'comingSoon' in link && link.comingSoon ? (
            <button
              class="contact__item contact__item--soon"
              style={`--brand-color: ${link.color}`}
              type="button"
              data-coming-soon
            >
              <Icon name={link.icon} class="contact__icon" />
              <span class="contact__name">{link.name}</span>
            </button>
          ) : 'email' in link && link.email ? (
            <button
              class="contact__item contact__item--soon"
              style={`--brand-color: ${link.color}`}
              type="button"
              data-email={link.email}
            >
              <Icon name={link.icon} class="contact__icon" />
              <span class="contact__name">{link.name}</span>
            </button>
          ) : (
            <a
              href={link.url}
              class="contact__item"
              style={`--brand-color: ${link.color}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Icon name={link.icon} class="contact__icon" />
              <span class="contact__name">{link.name}</span>
            </a>
          )}
        </li>
      ))
    }
  </ul>
  <p class="contact__copy">&copy; 2026 Haruworld</p>
</div>
<div class="contact__toast" id="coming-soon-toast">準備中です。。＞＜</div>
<div class="contact__toast contact__toast--email" id="email-toast">
  <span class="contact__email-text">h.minemura.0x@gmail.com</span>
  <button class="contact__email-copy" id="email-copy-btn" type="button">Copy</button>
</div>

<style>
  .contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    padding: 4rem 0;
  }

  .contact__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 3rem;
  }

  .contact__copy {
    font-family: var(--font-main);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .contact__item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
  }

  .contact__icon {
    width: 48px;
    height: 48px;
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }

  .contact__item:hover .contact__icon {
    color: var(--brand-color);
  }

  .contact__name {
    position: absolute;
    bottom: -1.75rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-main);
    font-size: 0.75rem;
    color: var(--brand-color);
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  .contact__item:hover .contact__name {
    opacity: 1;
  }

  .contact__item--soon {
    background: none;
    border: none;
    font: inherit;
    cursor: pointer;
  }

  .contact__toast {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.9);
    font-family: var(--font-main);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: 8px;
    padding: 1.5rem 2.5rem;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
    z-index: 300;
    pointer-events: none;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .contact__toast.is-visible {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    pointer-events: auto;
  }

  .contact__toast--email {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .contact__email-text {
    font-family: var(--font-main);
    font-size: 0.9rem;
    color: var(--color-text);
    user-select: all;
  }

  .contact__email-copy {
    font-family: var(--font-main);
    font-size: 0.75rem;
    color: var(--color-bg);
    background: var(--color-text);
    border: none;
    border-radius: 4px;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .contact__email-copy:hover {
    opacity: 0.7;
  }
</style>

<script>
  function hideAllToasts(): void {
    document.querySelectorAll('.contact__toast').forEach((t) => t.classList.remove('is-visible'));
  }

  document.querySelectorAll('[data-coming-soon]').forEach((btn) => {
    btn.addEventListener('click', () => {
      hideAllToasts();
      const toast = document.getElementById('coming-soon-toast');
      if (!toast) return;
      toast.classList.add('is-visible');
      setTimeout(() => toast.classList.remove('is-visible'), 2000);
    });
  });

  document.querySelectorAll('[data-email]').forEach((btn) => {
    btn.addEventListener('click', () => {
      hideAllToasts();
      const toast = document.getElementById('email-toast');
      if (!toast) return;
      toast.classList.add('is-visible');
    });
  });

  document.getElementById('email-copy-btn')?.addEventListener('click', () => {
    const btn = document.getElementById('email-copy-btn');
    navigator.clipboard.writeText('h.minemura.0x@gmail.com');
    if (btn) btn.textContent = 'Copied!';
    setTimeout(() => {
      if (btn) btn.textContent = 'Copy';
      document.getElementById('email-toast')?.classList.remove('is-visible');
    }, 1500);
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.contact__toast') && !target.closest('[data-email]') && !target.closest('[data-coming-soon]')) {
      hideAllToasts();
    }
  });
</script>
