---
import { Icon } from 'astro-icon/components';

const links = [
  {
    name: 'GitHub',
    icon: 'simple-icons:github',
    color: '#181717',
    url: 'https://github.com/ramune0x0',
  },
  {
    name: 'Email',
    icon: 'mdi:email-outline',
    color: '#1a1a1a',
    url: 'mailto:h.minemura.0x@gmail.com',
  },
] as const;
---

<section id="contact" class="section">
  <div class="section__split">
    <div class="section__left">
      <span class="section__number">04</span>
      <span class="section__label">Contact</span>
    </div>
    <div class="contact__right" data-animate>
      <ul class="contact__list">
        {
          links.map((link) => (
            <li>
              <a
                href={link.url}
                class="contact__item"
                style={`--brand-color: ${link.color}`}
                target={link.url.startsWith('http') ? '_blank' : undefined}
                rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
              >
                <Icon name={link.icon} class="contact__icon" />
                <span class="contact__name">{link.name}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .contact__list {
    display: flex;
    gap: 2.5rem;
  }

  .contact__item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
  }

  .contact__icon {
    width: 40px;
    height: 40px;
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }

  .contact__item:hover .contact__icon {
    color: var(--brand-color);
  }

  .contact__name {
    position: absolute;
    bottom: -1.75rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-main);
    font-size: 0.7rem;
    color: var(--brand-color);
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  .contact__item:hover .contact__name {
    opacity: 1;
  }
</style>
