---

<section class="hero">
  <canvas class="hero__canvas" id="hero-canvas"></canvas>
  <div class="hero__inner">
    <div class="hero__text">
      <p class="hero__role" id="hero-role"></p>
      <h1 class="hero__name" id="hero-name"></h1>
      <span class="hero__cursor" id="hero-cursor">|</span>
    </div>
    <img
      class="hero__avatar"
      src="https://github.com/ramune0x0.png"
      alt="Haru"
      width="200"
      height="200"
    />
  </div>
</section>

<script>
  // ── タイプライターアニメーション ──
  const roleEl = document.getElementById('hero-role')!;
  const nameEl = document.getElementById('hero-name')!;
  const cursorEl = document.getElementById('hero-cursor')!;

  const ROLE_TEXT = 'Engineer & Designer';
  const NAME_TEXT = 'Haru';
  const TYPE_SPEED = 60;
  const PAUSE = 400;

  function typeText(
    el: HTMLElement,
    text: string,
    speed: number,
  ): Promise<void> {
    return new Promise((resolve) => {
      let i = 0;
      // カーソルをこの要素の横に移動
      el.after(cursorEl);
      const interval = setInterval(() => {
        el.textContent += text[i];
        i++;
        if (i >= text.length) {
          clearInterval(interval);
          resolve();
        }
      }, speed);
    });
  }

  async function startTyping(): Promise<void> {
    await new Promise((r) => setTimeout(r, 600));
    await typeText(roleEl, ROLE_TEXT, TYPE_SPEED);
    await new Promise((r) => setTimeout(r, PAUSE));
    await typeText(nameEl, NAME_TEXT, TYPE_SPEED + 40);
    // タイピング完了後、カーソルは点滅のみ
    cursorEl.classList.add('is-done');
  }

  startTyping();

  // ── Canvas パーティクル ──
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let mouse = { x: -1000, y: -1000 };
  const PARTICLE_COUNT = 80;
  const MOUSE_RADIUS = 150;

  interface Particle {
    x: number;
    y: number;
    baseX: number;
    baseY: number;
    size: number;
    alpha: number;
  }

  let particles: Particle[] = [];

  function resize(): void {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
    initParticles();
  }

  function initParticles(): void {
    particles = Array.from({ length: PARTICLE_COUNT }, () => {
      const x = Math.random() * canvas.width;
      const y = Math.random() * canvas.height;
      return {
        x,
        y,
        baseX: x,
        baseY: y,
        size: Math.random() * 1.5 + 0.5,
        alpha: Math.random() * 0.3 + 0.05,
      };
    });
  }

  function draw(): void {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (const p of particles) {
      const dx = mouse.x - p.x;
      const dy = mouse.y - p.y;
      const dist = Math.sqrt(dx * dx + dy * dy);

      const proximity = Math.max(0, 1 - dist / MOUSE_RADIUS);
      const alpha = p.alpha + proximity * 0.6;

      if (dist < MOUSE_RADIUS) {
        p.x -= dx * 0.02;
        p.y -= dy * 0.02;
      } else {
        p.x += (p.baseX - p.x) * 0.02;
        p.y += (p.baseY - p.y) * 0.02;
      }

      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(123, 104, 168, ${alpha})`;
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }

  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });

  canvas.addEventListener('mouseleave', () => {
    mouse = { x: -1000, y: -1000 };
  });

  window.addEventListener('resize', resize);
  resize();
  draw();
</script>

<style>
  .hero {
    min-height: 100dvh;
    display: flex;
    align-items: flex-end;
    position: relative;
    padding: 4rem;
    overflow: hidden;
  }

  .hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 3rem;
  }

  .hero__avatar {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    flex-shrink: 0;
    opacity: 0;
    animation: hero-in 0.8s ease forwards 0.1s;
  }

  @keyframes hero-in {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero__role {
    font-family: var(--font-main);
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--color-text-muted);
    letter-spacing: 0.15em;
    min-height: 1.5em;
    margin-bottom: 0.75rem;
  }

  .hero__name {
    font-family: var(--font-main);
    font-size: clamp(4rem, 12vw, 10rem);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.04em;
    line-height: 0.9;
    min-height: 1em;
    display: inline;
  }

  .hero__cursor {
    font-family: var(--font-main);
    font-size: clamp(4rem, 12vw, 10rem);
    font-weight: 400;
    color: var(--color-text);
    line-height: 0.9;
    animation: blink 0.8s step-end infinite;
    user-select: none;
  }

  .hero__cursor.is-done {
    animation: blink 1.2s step-end infinite;
    opacity: 0.5;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 1.5rem;
    }

    .hero__inner {
      flex-direction: column-reverse;
      align-items: flex-start;
    }

    .hero__avatar {
      width: 140px;
      height: 140px;
    }
  }
</style>
