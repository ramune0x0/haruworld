---

<section class="hero">
  <!-- 装飾ライン（タイピング完了で表示） -->
  <svg class="hero__line hero__line--top" id="hero-line-top" viewBox="0 0 1400 2" preserveAspectRatio="none">
    <line x1="0" y1="1" x2="1400" y2="1" stroke="#e2e0db" stroke-width="1" />
  </svg>
  <svg class="hero__line hero__line--bottom" id="hero-line-bottom" viewBox="0 0 1400 2" preserveAspectRatio="none">
    <line x1="0" y1="1" x2="1400" y2="1" stroke="#e2e0db" stroke-width="1" />
  </svg>

  <div class="hero__inner">
    <div class="hero__label">
      <span class="hero__role" id="hero-role"></span>
      <span class="hero__cursor-sm" id="hero-cursor-sm">|</span>
    </div>
    <div class="hero__title-row">
      <h1 class="hero__name" id="hero-name"></h1>
      <span class="hero__cursor-lg" id="hero-cursor-lg">|</span>
    </div>
  </div>

  <div class="hero__scroll-hint" id="hero-scroll-hint">
    <span>Scroll</span>
  </div>
</section>

<script>
  const roleEl = document.getElementById('hero-role')!;
  const nameEl = document.getElementById('hero-name')!;
  const cursorSm = document.getElementById('hero-cursor-sm')!;
  const cursorLg = document.getElementById('hero-cursor-lg')!;
  const lineTop = document.getElementById('hero-line-top')!;
  const lineBottom = document.getElementById('hero-line-bottom')!;
  const scrollHint = document.getElementById('hero-scroll-hint')!;

  const ROLE_TEXT = 'Engineer & Designer';
  const NAME_TEXT = 'Haruworld';
  const TYPE_SPEED = 60;
  const PAUSE = 400;

  cursorLg.style.opacity = '0';

  function typeText(el: HTMLElement, text: string, speed: number): Promise<void> {
    return new Promise((resolve) => {
      let i = 0;
      const interval = setInterval(() => {
        el.textContent += text[i];
        i++;
        if (i >= text.length) {
          clearInterval(interval);
          resolve();
        }
      }, speed);
    });
  }

  async function startTyping(): Promise<void> {
    document.body.style.overflow = 'hidden';

    await new Promise((r) => setTimeout(r, 400));
    await typeText(roleEl, ROLE_TEXT, TYPE_SPEED);
    await new Promise((r) => setTimeout(r, PAUSE));
    cursorSm.style.display = 'none';
    cursorLg.style.opacity = '1';
    await typeText(nameEl, NAME_TEXT, TYPE_SPEED + 40);
    cursorLg.classList.add('is-done');

    // 完了の合図: ラインが走る + スクロールヒント表示
    await new Promise((r) => setTimeout(r, 300));
    lineTop.classList.add('is-visible');
    lineBottom.classList.add('is-visible');
    await new Promise((r) => setTimeout(r, 600));
    scrollHint.classList.add('is-visible');
    document.body.style.overflow = '';
  }

  startTyping();
</script>

<style>
  .hero {
    height: 100dvh;
    display: flex;
    align-items: center;
    position: relative;
    padding: 4rem;
    overflow: hidden;
  }

  /* 装飾ライン */
  .hero__line {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    z-index: 1;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero__line.is-visible {
    clip-path: inset(0 0 0 0);
  }

  .hero__line--top { top: 30%; }
  .hero__line--bottom { bottom: 20%; transition-delay: 0.15s; }

  .hero__inner {
    position: relative;
    z-index: 2;
  }

  .hero__label {
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
  }

  .hero__role {
    font-family: var(--font-main);
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--color-text-muted);
    letter-spacing: 0.2em;
  }

  .hero__cursor-sm {
    font-family: var(--font-main);
    font-size: 0.85rem;
    color: var(--color-text);
    animation: blink 0.8s step-end infinite;
    user-select: none;
  }

  .hero__title-row {
    display: flex;
    align-items: baseline;
  }

  .hero__name {
    font-family: var(--font-main);
    font-size: clamp(3.5rem, 11vw, 9rem);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .hero__cursor-lg {
    font-family: var(--font-main);
    font-size: clamp(3.5rem, 11vw, 9rem);
    font-weight: 400;
    color: var(--color-text);
    line-height: 1;
    animation: blink 0.8s step-end infinite;
    user-select: none;
    transition: opacity 0.2s ease;
  }

  .hero__cursor-lg.is-done {
    animation: blink 1.2s step-end infinite;
    opacity: 0.3;
  }

  /* スクロールヒント */
  .hero__scroll-hint {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    transition: opacity 0.6s ease;
    z-index: 2;
  }

  .hero__scroll-hint.is-visible {
    opacity: 1;
  }

  .hero__scroll-hint span {
    font-family: var(--font-main);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.2em;
    animation: hint-bounce 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @keyframes hint-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  @media (max-width: 768px) {
    .hero { padding: 3rem 1.5rem; }
  }
</style>
