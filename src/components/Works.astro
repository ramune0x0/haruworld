---
import { Icon } from 'astro-icon/components';

const techMap: Record<string, { icon: string; color: string }> = {
  'C': { icon: 'simple-icons:c', color: '#A8B9CC' },
  'C++': { icon: 'simple-icons:cplusplus', color: '#00599C' },
  'C#': { icon: 'simple-icons:csharp', color: '#512BD4' },
  'TypeScript': { icon: 'simple-icons:typescript', color: '#3178C6' },
  'JavaScript': { icon: 'simple-icons:javascript', color: '#F7DF1E' },
  'Linux': { icon: 'simple-icons:linux', color: '#FCC624' },
  'Git': { icon: 'simple-icons:git', color: '#F05032' },
  'Unity': { icon: 'simple-icons:unity', color: '#000000' },
  'n8n': { icon: 'simple-icons:n8n', color: '#EA4B71' },
  'Supabase': { icon: 'simple-icons:supabase', color: '#3FCF8E' },
  'Express.js': { icon: 'simple-icons:express', color: '#000000' },
  'Google APIs': { icon: 'simple-icons:google', color: '#4285F4' },
  'Next.js': { icon: 'simple-icons:nextdotjs', color: '#000000' },
  'React': { icon: 'simple-icons:react', color: '#61DAFB' },
  'Figma': { icon: 'simple-icons:figma', color: '#F24E1E' },
};

const works = [
  {
    id: 'w1',
    title: '42 Tokyo カリキュラム',
    period: '2025.04 —',
    description: 'C / C++ で低レイヤーを学習',
    summary: '講師・教材なしのピアラーニング環境で、C / C++ を中心にOS・プロセス・メモリ管理などの低レイヤー領域を学習。',
    details: [
      'C標準ライブラリ関数（strlen, memcpy等）の再実装',
      'bash風シェルをCで実装（トークナイザ・パーサー・エグゼキューター）',
      'mutex を用いたマルチスレッドの排他制御（食事する哲学者問題）',
    ],
    tech: ['C', 'C++', 'Linux', 'Git'],
  },
  {
    id: 'w2',
    title: '3D オンライン対戦ゲーム',
    period: '2025.09',
    description: 'ハッカソン 最優秀賞・企業賞',
    summary: 'Progate ハッカソンで5名チームで制作した、Wii のゲームソフトをオマージュしたリアルタイム3Dオンライン対戦ゲーム。',
    details: [
      'ゲームUI（スコア表示、メニュー画面、対戦画面）の設計・実装を担当',
      'リアルタイム対戦のネットワーク通信処理の一部を実装',
      '最優秀賞・企業賞を受賞',
    ],
    tech: ['C#', 'Unity'],
    client: { name: '受賞ポスト (X)', url: 'https://x.com/_58hack/status/1969732435245224145' },
  },
  {
    id: 'w3',
    title: 'CODE BLUE 2025 学生スタッフ',
    period: '2025',
    description: 'セキュリティカンファレンスの運営',
    summary: '国際セキュリティカンファレンス CODE BLUE 2025 に学生スタッフとして参加。',
    details: [
      'カンファレンス運営の学生スタッフとして従事',
    ],
    tech: [],
  },
  {
    id: 'w4',
    title: '業務自動化・システム改善',
    period: '2025.12 —',
    description: 'n8n ワークフロー自動化 3件',
    summary: 'n8n を用いた業務ワークフロー自動化3件の構築と、既存の予約管理・サポートシステムのバックエンドリファクタリング。',
    details: [
      'サイト制作プロセスの入力作業を n8n で自動化',
      '問い合わせメールの自動返信ワークフローを構築',
      'アポ獲得時の顧客データ処理・Meet URL 自動発行',
      '既存システムのエラーハンドリング改善（null 返却問題）',
      'OAuth 2.0 認証クライアントの競合を修正',
    ],
    tech: ['TypeScript', 'JavaScript', 'n8n', 'Supabase', 'Express.js', 'Google APIs'],
  },
  {
    id: 'w5',
    title: '企業 Web サイト制作',
    period: '2026.02',
    description: 'コーポレートサイト制作・ロゴデザイン',
    summary: 'コーポレートサイトのフロントエンド制作からロゴデザインまでを一貫して担当した受託開発。',
    details: [
      'デザイン仮案を作成し、クライアントとすり合わせた上で実装',
      'スクロール連動やトランジション等の動的な UI を実装',
      'Figma でコーポレートロゴをデザイン・制作',
    ],
    tech: ['TypeScript', 'Next.js', 'React', 'Figma'],
    client: { name: 'Clean Robotics株式会社', url: 'https://cleanrobotics.co.jp/' },
  },
] as const;
---

<section id="works" class="section" style="position: relative;">
  <svg style="position: absolute; top: 0; right: 0; width: 50%; height: 2px;" viewBox="0 0 1400 2" preserveAspectRatio="none">
    <line x1="0" y1="1" x2="1400" y2="1" stroke="#e2e0db" stroke-width="1" />
  </svg>
  <div class="section__split">
    <div class="section__left">
      <span class="section__number">02</span>
      <span class="section__label">Works</span>
    </div>
    <div class="works__area" data-animate>
      <div class="works__two-col">
        <div class="works__timeline">
          {
            works.map((work, i) => (
              <button
                class="works__item"
                data-work={work.id}
                data-animate
                data-delay={i * 120}
                type="button"
              >
                <div class="works__dot" />
                <div class="works__body">
                  <span class="works__period">{work.period}</span>
                  <h3 class="works__title">{work.title}</h3>
                  <p class="works__desc">{work.description}</p>
                </div>
              </button>
            ))
          }
        </div>
        <div class="works__bubble-area">
          {
            works.map((work) => (
              <div class="works__bubble" id={`bubble-${work.id}`}>
                <span class="works__bubble-period">{work.period}</span>
                <h4 class="works__bubble-title">{work.title}</h4>
                <p class="works__bubble-summary">{work.summary}</p>
                <ul class="works__bubble-list">
                  {work.details.map((d) => <li>{d}</li>)}
                </ul>
                {work.tech.length > 0 && (
                  <div class="works__bubble-tech">
                    {work.tech.map((t) => {
                      const info = techMap[t];
                      return info ? (
                        <span class="works__bubble-icon" style={`color: ${info.color}`} title={t}>
                          <Icon name={info.icon} />
                        </span>
                      ) : null;
                    })}
                  </div>
                )}
                {'client' in work && work.client && (
                  <a
                    href={work.client.url}
                    class="works__bubble-link"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {work.client.name} →
                  </a>
                )}
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<!-- モバイル用モーダル -->
{
  works.map((work) => (
    <div class="works__modal" id={`modal-${work.id}`}>
      <div class="works__modal-backdrop" data-modal-close />
      <div class="works__modal-content">
        <button class="works__modal-close" data-modal-close type="button">&times;</button>
        <span class="works__bubble-period">{work.period}</span>
        <h4 class="works__bubble-title">{work.title}</h4>
        <p class="works__bubble-summary">{work.summary}</p>
        <ul class="works__bubble-list">
          {work.details.map((d) => <li>{d}</li>)}
        </ul>
        {work.tech.length > 0 && (
          <div class="works__bubble-tech">
            {work.tech.map((t) => {
              const info = techMap[t];
              return info ? (
                <span class="works__bubble-icon" style={`color: ${info.color}`} title={t}>
                  <Icon name={info.icon} />
                </span>
              ) : null;
            })}
          </div>
        )}
        {'client' in work && work.client && (
          <a
            href={work.client.url}
            class="works__bubble-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            {work.client.name} →
          </a>
        )}
      </div>
    </div>
  ))
}

<script>
  const isMobile = () => window.innerWidth <= 768;

  document.querySelectorAll<HTMLButtonElement>('[data-work]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.work;

      if (isMobile()) {
        // モバイル: モーダル表示
        const modal = document.getElementById(`modal-${id}`);
        modal?.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      } else {
        // PC: 右カラム吹き出し
        const bubble = document.getElementById(`bubble-${id}`);
        const isOpen = bubble?.classList.contains('is-open');

        document.querySelectorAll('.works__bubble.is-open').forEach((b) => {
          b.classList.remove('is-open');
        });
        document.querySelectorAll('.works__item.is-active').forEach((b) => {
          b.classList.remove('is-active');
        });

        if (!isOpen) {
          bubble?.classList.add('is-open');
          btn.classList.add('is-active');
        }
      }
    });
  });

  // モーダルを閉じる
  document.querySelectorAll('[data-modal-close]').forEach((el) => {
    el.addEventListener('click', () => {
      el.closest('.works__modal')?.classList.remove('is-open');
      document.body.style.overflow = '';
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelector('.works__modal.is-open')?.classList.remove('is-open');
      document.body.style.overflow = '';
    }
  });
</script>

<style>
  .works__area { position: relative; }

  .works__two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .works__timeline {
    position: relative;
    padding-left: 2rem;
    display: flex;
    flex-direction: column;
  }

  .works__timeline::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 1px;
    background: var(--color-border);
  }

  .works__item {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.25rem 1rem 1.25rem 0;
    background: none;
    border: none;
    color: inherit;
    font: inherit;
    cursor: pointer;
    text-align: left;
    transition: color 0.3s ease;
    width: 100%;
  }

  .works__item:hover,
  .works__item.is-active {
    color: var(--color-accent);
  }

  .works__dot {
    position: absolute;
    left: -2rem;
    top: 1.5rem;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background: var(--color-bg);
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .works__item:hover .works__dot,
  .works__item.is-active .works__dot {
    border-color: var(--color-accent);
    background: var(--color-accent);
  }

  .works__period {
    font-family: var(--font-terminal);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
    min-width: 90px;
    flex-shrink: 0;
  }

  .works__title {
    font-family: var(--font-main), var(--font-jp);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .works__desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  /* ─── Bubble (右カラム) ─── */
  .works__bubble-area {
    position: relative;
    min-height: 100px;
  }

  .works__bubble {
    display: none;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.04);
    animation: bubble-in 0.3s ease;
  }

  .works__bubble.is-open {
    display: block;
  }

  @keyframes bubble-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .works__bubble-period {
    font-family: var(--font-terminal);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
  }

  .works__bubble-title {
    font-family: var(--font-main), var(--font-jp);
    font-size: 1rem;
    font-weight: 700;
    margin: 0.25rem 0 1rem;
    color: var(--color-accent);
  }

  .works__bubble-summary {
    font-size: 0.85rem;
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .works__bubble-list {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    padding-left: 1rem;
    list-style: disc;
    margin-bottom: 1rem;
  }

  .works__bubble-list li {
    margin-bottom: 0.25rem;
  }

  .works__bubble-tech {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .works__bubble-icon {
    display: flex;
    align-items: center;
  }

  .works__bubble-icon svg {
    width: 18px;
    height: 18px;
  }

  .works__bubble-link {
    font-family: var(--font-main);
    font-size: 0.75rem;
    color: var(--color-accent);
    transition: opacity 0.3s ease;
  }

  .works__bubble-link:hover {
    opacity: 0.7;
  }

  /* ─── Mobile Modal ─── */
  .works__modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    align-items: center;
    justify-content: center;
  }

  .works__modal.is-open {
    display: flex;
  }

  .works__modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(4px);
  }

  .works__modal-content {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 2rem;
    width: 90%;
    max-width: 400px;
    max-height: 80vh;
    overflow-y: auto;
    animation: bubble-in 0.3s ease;
  }

  .works__modal-close {
    position: absolute;
    top: 0.75rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--color-text-muted);
    cursor: pointer;
    line-height: 1;
  }

  .works__modal-close:hover {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .works__two-col {
      grid-template-columns: 1fr;
    }

    .works__bubble-area {
      display: none;
    }

    .works__item {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
